<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bioColorBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_app_logo"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="6dp"
            android:contentDescription="fortispass" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layoutDirection="ltr"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="fortis"
                android:textSize="24sp"
                android:fontFamily="@font/space_grotesk_semibold"
                android:textColor="#0666CC" />
            <TextView
                android:id="@+id/tv_pass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="pass"
                android:textSize="24sp"
                android:fontFamily="@font/space_grotesk_semibold"
                android:textColor="@color/white" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_subtitle"
            android:textSize="14sp"
            android:textColor="?attr/bioColorText2"
            android:textAlignment="center"
            android:layout_marginBottom="40dp"
            android:lineSpacingMultiplier="1.4" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/relay_url_label"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/bioColorText"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_relay_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/relay_url_hint"
            android:inputType="textUri"
            android:textColor="?attr/bioColorText"
            android:textColorHint="?attr/bioColorText3"
            android:backgroundTint="?attr/bioColorBorder"
            android:padding="14dp"
            android:textSize="15sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/device_name_label"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/bioColorText"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_device_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/device_name_hint"
            android:inputType="text"
            android:textColor="?attr/bioColorText"
            android:textColorHint="?attr/bioColorText3"
            android:backgroundTint="?attr/bioColorBorder"
            android:padding="14dp"
            android:textSize="15sp"
            android:layout_marginBottom="36dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:text="@string/btn_register"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="?attr/bioColorAccent"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp"
            app:icon="@drawable/ic_plus"
            app:iconGravity="start"
            app:iconPadding="10dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_log_in_vault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/btn_import_migration"
            android:textSize="15sp"
            android:textColor="?attr/bioColorText2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="10dp"
            app:icon="@drawable/ic_logout"
            app:iconGravity="start"
            app:iconPadding="10dp"
            app:iconTint="?attr/bioColorText2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/btn_settings"
            android:textSize="15sp"
            android:textColor="?attr/bioColorText2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="16dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="start"
            app:iconPadding="10dp"
            app:iconTint="?attr/bioColorText2" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textAlignment="center"
            android:textColor="?attr/bioColorText2"
            android:lineSpacingMultiplier="1.4"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
