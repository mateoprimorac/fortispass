<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="?attr/bioColorBg">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_app_logo"
        android:layout_marginBottom="6dp"
        android:contentDescription="fortispass" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layoutDirection="ltr"
        android:layout_marginBottom="48dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="fortis"
            android:textSize="22sp"
            android:fontFamily="@font/space_grotesk_semibold"
            android:textColor="#0666CC" />
        <TextView
            android:id="@+id/tv_pass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="pass"
            android:textSize="22sp"
            android:fontFamily="@font/space_grotesk_semibold"
            android:textColor="@color/white" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_scan_qr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:paddingVertical="14dp"
        android:text="@string/btn_scan_qr"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="?attr/bioColorAccent"
        android:textColor="@color/white"
        android:layout_marginBottom="12dp"
        app:icon="@drawable/ic_qr_code"
        app:iconGravity="start"
        app:iconPadding="10dp"
        app:iconTint="@color/white" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="52dp"
        android:paddingVertical="12dp"
        android:text="@string/btn_settings"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="?attr/bioColorText2"
        app:icon="@drawable/ic_settings"
        app:iconGravity="start"
        app:iconPadding="10dp"
        app:iconTint="?attr/bioColorText2" />

</LinearLayout>
