<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Stroke color is set programmatically in QRScanActivity from the theme accent.
         Default is fortispass blue (#3A6FD8 at ~53% opacity) as fallback. -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#883A6FD8" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
