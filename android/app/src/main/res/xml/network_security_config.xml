<?xml version="1.0" encoding="utf-8"?>
<!-- Allows cleartext HTTP for local dev (LAN IP addresses).
     Remove or restrict this before any production release. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
