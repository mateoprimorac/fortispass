# Copy this file to .env and replace every CHANGE_ME value before manual use.
# The recommended setup path is still: python server.py
# That launcher generates a matching .env automatically and keeps it in sync.

LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080

DATABASE_URL=postgresql://fortispass:CHANGE_ME@postgres:5432/fortispass
POSTGRES_PASSWORD=CHANGE_ME

REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

JWT_SECRET=CHANGE_ME_base64_32_bytes
SERVER_SIGN_KEY_SEED=CHANGE_ME_base64_32_bytes
SERVER_HMAC_KEY=CHANGE_ME_base64_32_bytes

SELF_HOSTED=true
DEPLOYMENT_MODE=local
RELAY_URL=http://127.0.0.1:8080
MAX_DEVICES_PER_VAULT=3
