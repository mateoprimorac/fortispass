# Copy this to .env and fill in real values.
# Generate secrets with: ./scripts/generate-secrets.sh
# NEVER commit .env to version control.

# Network
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080

# PostgreSQL
DATABASE_URL=postgresql://fortispass:CHANGE_ME@postgres:5432/fortispass
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# JWT signing key — base64-encoded 32 random bytes
JWT_SECRET=CHANGE_ME

# Ed25519 signing key seed — base64-encoded 32 random bytes
# Generate: python -c "import nacl.signing, base64; k=nacl.signing.SigningKey.generate(); print(base64.b64encode(bytes(k)).decode())"
SERVER_SIGN_KEY_SEED=CHANGE_ME

# HMAC key for recovery blob integrity — base64-encoded 32 random bytes
SERVER_HMAC_KEY=CHANGE_ME

# Deployment
SELF_HOSTED=true
RELAY_URL=https://relay.yourdomain.com
